# API keys (override values in config file if set)
MANTIS_ALCHEMY_KEY=
MANTIS_INFURA_KEY=

# Anthropic API key for the AI advisor (config field anthropic_api_key wins if set).
# Get one at https://console.anthropic.com — credits are billed separately from Claude.ai subscriptions.
ANTHROPIC_API_KEY=

# Redis (overrides cache.redis_url in config if set)
REDIS_URL=redis://127.0.0.1/

# Live-trading wallet private key (only set when wallet.private_key_env points here)
# WARNING: Never commit real keys. Prefer a file-based key via wallet.private_key_file.
MANTIS_PRIVATE_KEY=

# Logging
RUST_LOG=mantis=info,tokio_postgres=info
