# Cargo build artifacts
/target/

# Compiled library files
*.rlib

# Rust intermediate files
*.d

# Package metadata
*.lock

# MacOS specific files
.DS_Store

# Rust cache
/cargo/

# Configuration files from Rust toolchain or editors
.idea/
.vscode/

# Editor-specific files (common ones for macOS)
*.swp
*.swo
*~

# Ignore backup files
*~

# Ignore dependency directories
/.cargo

# Ignore generated docs
/target/doc/

# Local config files (may contain secrets)
mainnet_config.json
local_notes.md
*.local.json
.env
.env.*
!.env.example

# Runtime logs
/logs/

# Local developer scratch / bot output
bot.log
*.bot.log

# Bot runtime state
.mantis_state

